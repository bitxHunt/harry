generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

model enquiry {
  id         String   @id @default(uuid())
  name       String   @db.VarChar(50)
  email      String   @db.VarChar(255)
  message    String
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model subscription {
  id    String @id @default(uuid())
  email String @db.VarChar(255) @unique
  created_at DateTime @default(now()) @db.Timestamp(6)
}
